{
  "name": "wiki-rewriter",
  "version": "1.0.0",
  "description": "Local sentence-rewrite assistant for Wikipedia editing — flags MOS issues and suggests encyclopedic rewrites.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "evals": "node evals/run.js",
    "promote": "node evals/promote.js",
    "exemplars": "uv run --project ../ml wikidetect exemplars",
    "detect": "uv run --project ../ml wikidetect detect",
    "calibrate": "uv run --project ../ml wikidetect calibrate",
    "fetch-samples": "node ../detector/fetch-samples.js",
    "sweep": "node ../detector/sweep.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  }
}
